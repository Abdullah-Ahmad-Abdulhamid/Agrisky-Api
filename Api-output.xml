using Agrisky.Models;
using Agrisky.Models.Agrisky.Models;
using AgriskyApi.Dtos;
using AgriskyApi.IRepo;
using AgriskyApi.Services;
using Google.Apis.Auth;
using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;
using Microsoft.SqlServer.Server;

namespace AgriskyApi.Controllers
{
    [Route("api/[controller]")]
    [ApiController]
    [AllowAnonymous]
    public class AuthController : ControllerBase
    {
        private readonly IUserRepo _repo;
        private readonly IJwtServices _jwtService;
        private readonly IConfiguration _config;

        public AuthController(IUserRepo repo, IJwtServices jwtService, IConfiguration config)
        {
            _repo = repo;
            _jwtService = jwtService;
            _config = config;
        }

        // ── POST api/auth/register ────────────────────────────────────────────
        [HttpPost("register")]
        public async Task<IActionResult> Register([FromBody] RegisterModel model)
        {
            if (!ModelState.IsValid)
                return BadRequest(ModelState);

            var email = model.Email.Trim().ToLower();

            var user = new User
            {
                FirstName = model.FirstName.Trim(),
                LastName = model.LastName.Trim(),
                Email = email,
                PhoneNumber = model.PhoneNumber,
                Address = model.Address,
                Role = "User",
                PasswordHash = BCrypt.Net.BCrypt.HashPassword(model.Password)
            };

            var result = await _repo.RegisterUserAsync(user);

            if (!result)
                return Conflict(new { message = "Email is already registered." });

            return Ok(new { message = "Registration successful." });
        }

        // ── POST api/auth/login ───────────────────────────────────────────────
        [HttpPost("login")]
        public async Task<IActionResult> Login([FromBody] LoginModel model)
        {
            if (!ModelState.IsValid)
                return BadRequest(ModelState);

            var user = await _repo.GetUserByEmailAsync(model.Email.Trim().ToLower());

            if (user == null)
                return Unauthorized(new { message = "Invalid email or password." });

            // Social-only accounts have no password
            if (string.IsNullOrEmpty(user.PasswordHash))
                return Unauthorized(new { message = "This account uses Google sign-in. Please use 'Continue with Google'." });

            if (!BCrypt.Net.BCrypt.Verify(model.Password, user.PasswordHash))
                return Unauthorized(new { message = "Invalid email or password." });

            var token = _jwtService.GenerateToken(user);

            return Ok(new
            {
                token,
                user = new
                {
                    user.Id,
                    user.Email,
                    user.FirstName,
                    user.LastName,
                    user.Role,
                    user.ProfilePicture
                }
            });
        }

        // ── POST api/auth/google ──────────────────────────────────────────────
        // React sends the Google ID token (credential) from @react-oauth/google
        // Backend verifies it cryptographically using Google's public keys.
        [HttpPost("google")]
        public async Task<IActionResult> GoogleLogin([FromBody] GoogleLoginDto dto)
        {
            if (string.IsNullOrWhiteSpace(dto.IdToken))
                return BadRequest(new { message = "ID token is required." });

            // ── Step 1: Verify the ID token with Google ───────────────────────
            GoogleJsonWebSignature.Payload payload;
            try
            {
                var settings = new GoogleJsonWebSignature.ValidationSettings
                {
                    // Only accept tokens issued for YOUR Google Client ID
                    Audience = new[] { _config["Google:ClientId"] }
                };

                payload = await GoogleJsonWebSignature.ValidateAsync(dto.IdToken, settings);
            }
            catch (InvalidJwtException ex)
            {
                return Unauthorized(new { message = "Invalid Google token.", detail = ex.Message });
            }

            // ── Step 2: Find existing user or create a new one ────────────────
            var email = payload.Email.ToLower().Trim();
            var user = await _repo.GetUserByEmailAsync(email);

            if (user == null)
            {
                // New user — register them automatically
                user = new User
                {
                    FirstName = payload.GivenName ?? payload.Name?.Split(' ')[0] ?? "User",
                    LastName = payload.FamilyName ?? (payload.Name?.Contains(' ') == true
                                         ? string.Join(" ", payload.Name.Split(' ').Skip(1)) : ""),
                    Email = email,
                    GoogleId = payload.Subject,       // Google's unique user ID
                    ProfilePicture = payload.Picture,
                    Role = "User",
                    PasswordHash = null                   // No password for social users
                };

                var registered = await _repo.RegisterUserAsync(user);

                if (!registered)
                {
                    // Race condition: email appeared between check and insert — fetch it
                    user = await _repo.GetUserByEmailAsync(email);
                }
            }
            else
            {
                // Existing user — link Google account if not already linked
                bool changed = false;

                if (string.IsNullOrEmpty(user.GoogleId))
                {
                    user.GoogleId = payload.Subject;
                    changed = true;
                }
                if (payload.Picture != null && user.ProfilePicture != payload.Picture)
                {
                    user.ProfilePicture = payload.Picture;
                    changed = true;
                }

                if (changed)
                    await _repo.UpdateUserAsync(user);
            }

            // ── Step 3: Issue JWT ─────────────────────────────────────────────
            var token = _jwtService.GenerateToken(user!);

            return Ok(new
            {
                token,
                user = new
                {
                    user!.Id,
                    user.Email,
                    user.FirstName,
                    user.LastName,
                    user.Role,
                    user.ProfilePicture
                }
            });
        }
    }

    // ── Request DTO for Google endpoint ──────────────────────────────────────
    public class GoogleLoginDto
    {
        public string IdToken { get; set; } = string.Empty;
    }
}
